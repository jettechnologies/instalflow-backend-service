generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  COMPANY
  MARKETER
  CUSTOMER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InstallmentStatus {
  PENDING
  DUE
  OVERDUE
  DEFAULTED
  PAID
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CommissionStatus {
  ACTIVE
  PARTIALLY_RESERVED
  RESERVED
  PAID
  FROZEN
}

enum CommissionAllocationStatus {
  RESERVED
  PAID
  RELEASED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum SubscriptionInterval {
  WEEKLY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AccountType {
  ASSET
  LIABILITY
  REVENUE
  EXPENSE
  EQUITY
}

enum ApprovalAction {
  TOGGLE_ACTIVE
  SOFT_DELETE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InternalNotificationType {
  KYC_APPLICATION_SUBMITTED
  INSTALLMENT_OVERDUE
  PAYMENT_CONFIRMED
  COMMISSION_ACCRUED
  COMMISSION_TRANSFER_REQUEST
  COMMISSION_REQUEST_APPROVAL
  INSTALLMENT_REMINDER_3DAY
  INSTALLMENT_DUE_TODAY
  INSTALLMENT_OVERDUE_3DAY
  INSTALLMENT_OVERDUE_7DAY
  COMMISSION_TRANSFER_INITIATED
  COMMISSION_TRANSFER_SUCCESS
  COMMISSION_TRANSFER_FAILED
  COMMISSION_TRANSFER_REVERSED
  MARKETER_TOGGLE_REQUEST
  MARKETER_DELETE_REQUEST
  MARKETER_TOGGLE_APPROVED
  MARKETER_TOGGLE_REJECTED
  MARKETER_DELETE_APPROVED
  MARKETER_DELETE_REJECTED
  CONTRACT_WRITTEN_OFF
  CONTRACT_RESTRUCTURED
}

enum InternalNotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum FinancingStatus {
  PENDING_ACTIVATION
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
  REJECTED
  RESTRUCTURED
  WRITTEN_OFF
}

enum OnboardingStatus {
  PENDING
  PAYMENT_INITIALIZED
  PAID
  COMPLETED
  FAILED
}

enum CommissionPayoutStatus {
  PENDING_ADMIN_APPROVAL
  PENDING_COMPANY_APPROVAL
  APPROVED
  REJECTED
  TRANSFER_INITIATED
  PAID
  TRANSFER_FAILED
  TRANSFER_REVERSED
}

model Company {
  id        BigInt   @id @default(autoincrement())
  companyId String   @unique @default(uuid())
  name      String
  plan      String   @default("FREE")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                    User[]
  products                 Product[]
  subscriptions            CompanySubscription[]
  ledgerAccounts           LedgerAccount[]
  approvalRequests         ApprovalRequest[]
  commissionPayoutRequests CommissionPayoutRequest[]
}

model User {
  id                   BigInt   @id @default(autoincrement())
  userId               String   @unique @default(uuid())
  email                String   @unique
  password             String
  name                 String?
  role                 Role     @default(CUSTOMER)
  forcePasswordChange  Boolean  @default(false)
  companyId            String?
  company              Company? @relation(fields: [companyId], references: [companyId])
  referredByMarketerId String?
  referredByMarketer   User?    @relation("MarketerReferrals", fields: [referredByMarketerId], references: [userId])
  referredUsers        User[]   @relation("MarketerReferrals")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sessions              UserSession[]
  kycApplications       KycApplication[]       @relation("UserKyc")
  kycAuditTrails        KycAuditTrail[]
  internalNotifications InternalNotification[]

  referralCode   String?             @unique
  referrals      Referral[]
  commissions    Commission[]
  transactions   LedgerTransaction[]
  passwordResets PasswordReset[]

  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdById  String?
  creator      User?     @relation("UserCreator", fields: [createdById], references: [userId])
  createdUsers User[]    @relation("UserCreator")

  requestedApprovals ApprovalRequest[]   @relation("RequestedApprovals")
  targetedApprovals  ApprovalRequest[]   @relation("TargetedApprovals")
  financingContracts FinancingContract[]

  commissionPayoutRequests CommissionPayoutRequest[]

  adminApprovedPayouts CommissionPayoutRequest[] @relation("CommissionAdminApprover")

  companyApprovedPayouts      CommissionPayoutRequest[] @relation("CommissionCompanyApprover")
  marketerBankAccounts        MarketerBankAccount[]
  commissionTransferInitiator CommissionPayoutRequest[] @relation("TransferInitiator")
}

model UserSession {
  id        BigInt   @id @default(autoincrement())
  sessionId String   @unique @default(uuid()) @map("session_id")
  userId    BigInt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked   Boolean  @default(false)
}

model PasswordReset {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash   String   @map("otp_hash")
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Session {
  id        String   @id
  data      Json
  expiresAt DateTime
}

model Category {
  id          BigInt    @id @default(autoincrement())
  categoryId  String    @unique @default(uuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             BigInt                   @id @default(autoincrement())
  productId      String                   @unique @default(uuid())
  companyId      String?
  company        Company?                 @relation(fields: [companyId], references: [companyId])
  name           String
  slug           String                   @unique
  description    String?
  minPrice       Decimal?                 @map("min_price")
  maxPrice       Decimal?                 @map("max_price")
  stockQuantity  Int                      @default(0)
  price          Decimal                  @default(0)
  commissionRate Decimal                  @default(0)
  isActive       Boolean                  @default(true) @map("is_active")
  searchVector   Unsupported("tsvector")? @map("search_vector")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [categoryId])

  variants           ProductVariant[]
  referrals          Referral[]
  installmentPlans   ProductInstallmentPlan[]
  images             ProductImage[]
  kycApplications    KycApplication[]
  financingContracts FinancingContract[]
}

model ProductVariant {
  id                 BigInt              @id @default(autoincrement())
  variantId          String              @unique @default(uuid())
  productId          String
  product            Product             @relation(fields: [productId], references: [productId], onDelete: Cascade)
  sku                String              @unique
  size               String?
  color              String[] // PostgreSQL string array
  images             String[] // PostgreSQL string array
  stockQuantity      Int                 @default(0)
  price              Decimal             @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  financingContracts FinancingContract[]
}

model KycApplication {
  id                 BigInt                 @id @default(autoincrement())
  kycApplicationId   String                 @unique @default(uuid()) @map("kyc_application_id")
  userId             String                 @map("user_id")
  user               User                   @relation("UserKyc", fields: [userId], references: [userId])
  productId          String                 @map("product_id")
  product            Product                @relation(fields: [productId], references: [productId])
  installmentPlanId  String                 @map("installment_plan_id")
  installmentPlan    ProductInstallmentPlan @relation(fields: [installmentPlanId], references: [planId])
  variantId          String                 @map("variant_id")
  idType             String                 @map("id_type")
  idNumber           String                 @map("id_number")
  status             String                 @default("PENDING") // PENDING, APPROVED, REJECTED
  marketerApproved   Boolean                @default(false) @map("marketer_approved")
  marketerApprovedAt DateTime?              @map("marketer_approved_at")
  adminApproved      Boolean                @default(false) @map("admin_approved")
  adminApprovedAt    DateTime?              @map("admin_approved_at")
  rejectionReason    String?                @map("rejection_reason")
  legalHold          Boolean                @default(false) @map("legal_hold")
  isUnderFraudReview Boolean                @default(false) @map("is_under_fraud_review")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  kycDocumentAssets KycDocumentAsset[]
  kycAuditTrails    KycAuditTrail[]
  financingContract FinancingContract?
}

model KycDocumentAsset {
  id                  BigInt         @id @default(autoincrement())
  assetId             String         @unique @default(uuid()) @map("asset_id")
  kycApplicationId    String         @map("kyc_application_id")
  kycApplication      KycApplication @relation(fields: [kycApplicationId], references: [kycApplicationId], onDelete: Cascade)
  cloudinaryPublicId  String         @map("cloudinary_public_id")
  secureUrl           String         @map("secure_url")
  fileSize            Int            @map("file_size")
  mimeType            String         @map("mime_type")
  fileHash            String         @map("file_hash")
  isDeleted           Boolean        @default(false) @map("is_deleted")
  scheduledDeletionAt DateTime       @map("scheduled_deletion_at")
  deletedAt           DateTime?      @map("deleted_at")
  createdAt           DateTime       @default(now()) @map("created_at")
}

model KycAuditTrail {
  id               BigInt         @id @default(autoincrement())
  auditId          String         @unique @default(uuid()) @map("audit_id")
  kycApplicationId String         @map("kyc_application_id")
  kycApplication   KycApplication @relation(fields: [kycApplicationId], references: [kycApplicationId], onDelete: Cascade)
  action           String
  documentType     String         @map("document_type")
  fileHash         String         @map("file_hash")
  performedById    String?        @map("performed_by_id")
  performedBy      User?          @relation(fields: [performedById], references: [userId])
  outcome          String
  details          String?
  createdAt        DateTime       @default(now()) @map("created_at")
}

model FinancingContract {
  id         BigInt @id @default(autoincrement())
  contractId String @unique @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [userId])

  productId String
  product   Product @relation(fields: [productId], references: [productId])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [variantId])

  kycApplicationId String         @unique
  kycApplication   KycApplication @relation(fields: [kycApplicationId], references: [kycApplicationId])

  approvedProductPrice       Decimal
  approvedInterestPercentage Decimal
  approvedDurationMonths     Int

  principal     Decimal
  interest      Decimal
  totalFinanced Decimal

  status FinancingStatus @default(ACTIVE)

  installments Installment[]

  activatedAt DateTime?
  completedAt DateTime?
  defaultedAt DateTime?
  cancelledAt DateTime?
  rejectedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, productId])
}

model Installment {
  id            BigInt @id @default(autoincrement())
  installmentId String @unique @default(uuid())

  financingContractId String
  financingContract   FinancingContract @relation(fields: [financingContractId], references: [contractId])

  dueDate DateTime
  amount  Decimal

  sequence Int
  status   InstallmentStatus @default(PENDING)

  paidAt    DateTime? @map("paid_at")
  overdueAt DateTime? @map("overdue_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@unique([financingContractId, sequence])
}

model Payment {
  id                BigInt        @id @default(autoincrement())
  paymentId         String        @unique @default(uuid())
  installmentId     String
  installment       Installment   @relation(fields: [installmentId], references: [installmentId])
  amount            Decimal
  status            PaymentStatus @default(PENDING)
  providerReference String?       @unique
  idempotencyKey    String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  commissions       Commission[]
}

model Commission {
  id                    BigInt                 @id @default(autoincrement())
  commissionId          String                 @unique @default(uuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [userId])
  paymentId             String?
  payment               Payment?               @relation(fields: [paymentId], references: [paymentId])
  amount                Decimal
  status                CommissionStatus       @default(ACTIVE)
  reservedAmount        Decimal                @default(0) @map("reserved_amount")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  commissionAllocations CommissionAllocation[]
}

model CommissionAllocation {
  id              BigInt                     @id @default(autoincrement())
  allocationId    String                     @unique @default(uuid())
  payoutId        String
  payout          CommissionPayoutRequest    @relation(fields: [payoutId], references: [payoutId])
  commissionId    String
  commission      Commission                 @relation(fields: [commissionId], references: [commissionId])
  allocatedAmount Decimal                    @map("allocated_amount")
  status          CommissionAllocationStatus @default(RESERVED)
  createdAt       DateTime                   @default(now())

  @@unique([payoutId, commissionId])
  @@index([commissionId, status])
}

model CommissionPayoutRequest {
  id                    BigInt                 @id @default(autoincrement())
  payoutId              String                 @unique @default(uuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [userId])
  companyId             String
  transferCode          String?
  company               Company                @relation(fields: [companyId], references: [companyId])
  amount                Decimal
  status                CommissionPayoutStatus @default(PENDING_ADMIN_APPROVAL)
  requestedAt           DateTime               @default(now())
  adminApprovedById     String?
  adminApprovedBy       User?                  @relation("CommissionAdminApprover", fields: [adminApprovedById], references: [userId])
  adminApprovedAt       DateTime?
  companyApprovedById   String?
  companyApprovedBy     User?                  @relation("CommissionCompanyApprover", fields: [companyApprovedById], references: [userId])
  companyApprovedAt     DateTime?
  paidAt                DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  marketerBankAccount   MarketerBankAccount?   @relation(fields: [marketerBankAccountId], references: [id])
  marketerBankAccountId BigInt?
  transferInitiatedAt   DateTime?              @map("transfer_initiated_at")
  transferCompletedAt   DateTime?              @map("transfer_completed_at")
  transferFailedAt      DateTime?              @map("transfer_failed_at")
  transferFailReason    String?                @map("transfer_fail_reason")
  transferInitiatedById String?                @map("transfer_initiated_by_id")
  transferInitiatedBy   User?                  @relation("TransferInitiator", fields: [transferInitiatedById], references: [userId])
  commissionAllocations CommissionAllocation[]
}

model MarketerBankAccount {
  id            BigInt   @id @default(autoincrement())
  accountId     String   @unique @default(uuid()) @map("account_id")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  bankName      String   @map("bank_name")
  bankCode      String   @map("bank_code")
  accountName   String   @map("account_name")
  accountNumber String   @map("account_number")
  isPrimary     Boolean  @default(false) @map("is_primary")
  recipientCode String?  @map("recipient_code")
  isVerified    Boolean  @default(false) @map("is_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payoutRequests CommissionPayoutRequest[]

  @@unique([userId, accountNumber])
  @@index([userId])
}

model LedgerTransaction {
  id            BigInt          @id @default(autoincrement())
  transactionId String          @unique @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [userId])
  type          TransactionType
  amount        Decimal
  referenceId   String? // Tied to paymentId, commissionId, etc.
  description   String?
  createdAt     DateTime        @default(now()) // Append only, no update!
}

model Referral {
  id           BigInt   @id @default(autoincrement())
  referralId   String   @unique @default(uuid())
  marketerId   String
  marketer     User     @relation(fields: [marketerId], references: [userId])
  productId    String?
  product      Product? @relation(fields: [productId], references: [productId])
  referralCode String   @unique
  createdAt    DateTime @default(now())
}

model SubscriptionPlan {
  id                 BigInt               @id @default(autoincrement())
  planId             String               @unique @default(uuid())
  name               String               @unique
  description        String?
  price              Decimal
  discountPrice      Decimal?
  discountPercentage Decimal?
  interval           SubscriptionInterval @default(MONTHLY)
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  subscriptions     CompanySubscription[]
  onboardingIntents OnboardingIntent[]
}

model CompanySubscription {
  id             BigInt             @id @default(autoincrement())
  subscriptionId String             @unique @default(uuid())
  companyId      String
  company        Company            @relation(fields: [companyId], references: [companyId])
  planId         String
  plan           SubscriptionPlan   @relation(fields: [planId], references: [planId])
  status         SubscriptionStatus @default(PENDING)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model LedgerAccount {
  id               BigInt      @id @default(autoincrement())
  name             String // e.g., "PAYSTACK_CLEARING", "PLATFORM_REVENUE"
  type             AccountType
  balance          Decimal     @default(0)
  companyId        String? // Null for system-wide accounts
  company          Company?    @relation(fields: [companyId], references: [companyId])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  lastReconciledAt DateTime

  entries JournalEntry[]

  @@unique([name, companyId])
}

model FinancialTransaction {
  id          BigInt   @id @default(autoincrement())
  reference   String   @unique // e.g., Paystack Ref, Payout ID
  description String?
  metadata    Json? // Store raw gateway response
  createdAt   DateTime @default(now())

  entries JournalEntry[]
}

model JournalEntry {
  id              BigInt               @id @default(autoincrement())
  transactionId   BigInt
  transaction     FinancialTransaction @relation(fields: [transactionId], references: [id])
  ledgerAccountId BigInt
  account         LedgerAccount        @relation(fields: [ledgerAccountId], references: [id])
  debit           Decimal              @default(0)
  credit          Decimal              @default(0)
  reference       String               @unique // Unique for this specific line
  createdAt       DateTime             @default(now())
}

model WebhookEvent {
  id        String   @id // External Event ID (e.g. Paystack event ID)
  source    String // e.g., "PAYSTACK"
  type      String // e.g., "charge.success"
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([id])
}

model OnboardingIntent {
  id       BigInt @id @default(autoincrement())
  intentId String @unique @default(uuid())

  email        String @unique
  companyName  String
  adminName    String
  passwordHash String

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [planId])

  paymentReference String? @unique

  status OnboardingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentReference])
}

model ApprovalRequest {
  id            BigInt         @id @default(autoincrement())
  requestId     String         @unique @default(uuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [companyId])
  requestedById String
  requestedBy   User           @relation("RequestedApprovals", fields: [requestedById], references: [userId])
  reviewReason  String?
  reviewedAt    DateTime?
  targetUserId  String
  targetUser    User           @relation("TargetedApprovals", fields: [targetUserId], references: [userId])
  action        ApprovalAction
  reason        String?
  status        ApprovalStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProductInstallmentPlan {
  id                 BigInt           @id @default(autoincrement())
  planId             String           @unique @default(uuid())
  productId          String
  product            Product          @relation(fields: [productId], references: [productId], onDelete: Cascade)
  kycApplicationId   String?
  durationMonths     Int
  interestPercentage Decimal          @default(0)
  active             Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  kycApplications    KycApplication[]
}

model ProductImage {
  id                 BigInt   @id @default(autoincrement())
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId          BigInt
  imageUrl           String   @map("image_url")
  altText            String?  @map("alt_text")
  isPrimary          Boolean  @default(false) @map("is_primary")
  sortOrder          Int      @default(0) @map("sort_order")
  cloudinaryPublicId String?  @map("cloudinary_public_id")
  createdAt          DateTime @default(now()) @map("created_at")
}

model InternalNotification {
  id             BigInt                     @id @default(autoincrement())
  notificationId String                     @unique @default(uuid()) @map("notification_id")
  userId         String                     @map("user_id")
  user           User                       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  type           InternalNotificationType
  title          String
  message        String
  metadata       Json?
  status         InternalNotificationStatus @default(UNREAD)
  readAt         DateTime?                  @map("read_at")
  idempotencyKey String?                    @unique @map("idempotency_key")
  createdAt      DateTime                   @default(now()) @map("created_at")

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
}
